# Frontend Environment Variables
# Copy this file to .env.local and update with your values

# API Configuration
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# Feature Flags
NEXT_PUBLIC_USE_MOCKS=false
NEXT_PUBLIC_VERIFICATION_MODE=v1
NEXT_PUBLIC_USE_SSE=true
NEXT_PUBLIC_SSE_DEBUG=false
NEXT_PUBLIC_KPI_REFRESH_MS=15000
NEXT_PUBLIC_SHOW_KPI_DEBUG=false
NEXT_PUBLIC_RENDER_BEACON=true

# Feed Configuration
NEXT_PUBLIC_FEED_REFRESH_MS=60000

# Note: Only variables prefixed with NEXT_PUBLIC_ are available on the client side
# All other environment variables are server-side only
