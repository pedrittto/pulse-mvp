# Breaking Mode Configuration
BREAKING_MODE=1
VERIFICATION_MODE=v1
IMPACT_MODE=v3
CONFIDENCE_MODE=v2.2
BREAKING_LOG_LEVEL=info

# Frontend Configuration
NEXT_PUBLIC_VERIFICATION_MODE=v1

# Source Configuration
SOURCE_REQUEST_TIMEOUT_MS=8000

# Admin Authentication
# Single token (recommended)
ADMIN_TOKEN=your-admin-token-here

# Multiple tokens (comma-separated, optional)
# ADMIN_TOKENS=token1,token2,token3

# Enable destructive operations (purge, backfills)
# Set to 1 to allow purge operations
ADMIN_ALLOW_PURGE=0

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Firebase Configuration (replace with actual values)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=your-client-email
FIREBASE_PRIVATE_KEY=your-private-key

# Breaking Sources and Event Windows JSON (optional - will use files if not set)
# BREAKING_SOURCES_JSON={"sources":[...]}
# EVENT_WINDOWS_JSON={"events":[...]}
