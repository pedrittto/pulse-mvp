PORT=4000

# Enable Fastlane tighter polling for Tier-1
FASTLANE_ENABLED=1

# Per-host concurrency limit
LANE_PER_HOST_MAX=4

# Auto-demotion of slow sources
BREAKING_AUTODEMOTE=1
BREAKING_DEMOTE_WINDOW_MIN=30
BREAKING_DEMOTE_P50_MS=60000
BREAKING_DEMOTE_TTL_MS=3600000

# Optional: debug transport
# DEBUG_TRANSPORT=1

# XML worker pool
XML_WORKERS=2

# HTTP warmup and validators persistence
WARMUP_TIER1=1
WARMUP_CONCURRENCY=2
SSE_RING_SIZE=500
SSE_HEARTBEAT_MS=20000
BURST_WINDOW_MS=60000
BURST_MIN_INTERVAL_MS=2000
SPLAY_MAX_MS=700
WATCHDOG_ENABLED=0
WATCHDOG_INTERVAL_SEC=60
WATCHDOG_WINDOW_MIN=30
WATCHDOG_SLO_P50_MS=60000
WATCHDOG_SLO_P90_MS=120000
WATCHDOG_WEBHOOK_URL=
WATCHDOG_MIN_CONSECUTIVE_FAILS=2
WATCHDOG_MIN_CONSECUTIVE_RECOVERS=2
WATCHDOG_OPS_ENABLED=0
WATCHDOG_OPS_INTERVAL_SEC=60
WATCHDOG_EL_LAG_P95_MS=200
WATCHDOG_GC_P95_MS=150
WATCHDOG_CPU_P95_PCT=85
WATCHDOG_OPS_MIN_CONSECUTIVE=2
DEMOTE_WINDOW_MIN=30
DEMOTE_THRESHOLD_MS=60000
PROMOTE_THRESHOLD_MS=45000
PROMOTE_MAX_P90_MS=90000
PROMOTE_MIN_SAMPLES=10
DEMOTE_MIN_COOLDOWN_MS=1800000
DEMOTE_PENALTY_FACTOR=1.5
DEMOTE_MAX_COOLDOWN_MS=10800000

# Firestore BulkWriter
BULKWRITER_ENABLED=0
BULKWRITER_MAX_OPS_PER_SEC=500

# Clock drift
DRIFT_WINDOW_MIN=10
DRIFT_ALERT_P95_MS=2000
DRIFT_CORRECT_METRICS=1
ADMIN_API_ENABLED=0
ADMIN_API_TOKEN=
DRAIN_FETCH_TIMEOUT_MS=5000
DRAIN_SSE_CLOSE_MS=2000

# Social Fast-Signal Lane
SOCIAL_ENABLED=0
SOCIAL_PROVIDER=X
X_BEARER_TOKEN=
SOCIAL_POLL_MS=5000
SOCIAL_RATE_LIMIT_RPM=300
SOCIAL_MATCH_MIN_SCORE=0.6
SOCIAL_MAX_POST_AGE_SEC=120
SOCIAL_DEDUP_TTL_MS=600000
SOCIAL_WATCHLIST=
SOCIAL_BREAKING_ENABLED=1
SOCIAL_BREAKING_MIN_SCORE=0.75

# Webhook Ingestion (Direct Wires)
WEBHOOK_INGEST_ENABLED=0
WEBHOOK_HMAC_REQUIRED=1
WEBHOOK_HMAC_ALGO=sha256
WEBHOOK_PROVIDERS=prnewswire,globenewswire,businesswire
WEBHOOK_SHARED_SECRET_PRNEWSWIRE=
WEBHOOK_SHARED_SECRET_GLOBENEWSWIRE=
WEBHOOK_SHARED_SECRET_BUSINESSWIRE=
WEBHOOK_MAX_BODY_KB=256
WEBHOOK_QUEUE_CONCURRENCY=8
WEBHOOK_IDEMPOTENCY_TTL_MS=86400000

# Adaptive Poll Controller
CTRL_ENABLED=0
CTRL_TARGET_P50_MS=60000
CTRL_GLOBAL_RPS_MAX=8
CTRL_PER_HOST_RPS_MAX=3
CTRL_INTERVAL_MIN_MS=1500
CTRL_INTERVAL_MAX_MS=30000
CTRL_STEP_MS=1000
CTRL_HYST_MS=3000
CTRL_EVAL_WINDOW_MIN=15
CTRL_COOLDOWN_SEC=60
