{
  "name": "pulse-backend",
  "version": "0.1.0",
  "description": "Pulse MVP Backend",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --watch src --exec \"ts-node src/index.ts\"",
    "build": "rimraf dist && tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "backfill:facts": "ts-node --transpile-only scripts/backfillFacts.ts",
    "smoke:breaking": "node scripts/smoke-breaking.js",
    "kill:4000": "powershell -Command \"Get-NetTCPConnection -LocalPort 4000 -ErrorAction SilentlyContinue | ForEach-Object { Stop-Process -Id $_.OwningProcess -Force -ErrorAction SilentlyContinue }\"",
    "test": "jest"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "firebase-admin": "^12.0.0",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.10.0",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^6.0.3",
    "@types/xml2js": "^0.4.14",
    "dotenv": "^17.2.1",
    "husky": "^9.1.7",
    "jest": "^30.0.5",
    "nodemon": "^3.0.2",
    "rimraf": "^6.0.1",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.2"
  },
  "keywords": [
    "pulse",
    "backend",
    "express"
  ],
  "author": "",
  "license": "MIT"
}
