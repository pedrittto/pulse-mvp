{
  "name": "pulse-backend",
  "version": "0.1.0",
  "description": "Pulse MVP Backend",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node --enable-source-maps dist/index.js",
    "latency:oneclick": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/latency-oneclick.ps1",
    "latency:now": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/latency-now.ps1",
    "soak:breaking": "node ./scripts/soak-breaking.js",
    "verify:warmup": "node ./scripts/verify-warmup.js",
    "verify:sse": "node ./scripts/verify-sse-replay.js",
    "verify:feed": "node ./scripts/verify-feed-indexes.js",
    "print:ops": "node ./scripts/print-ops.js",
    "print:drift": "node ./scripts/print-drift.js",
    "print:render": "node ./scripts/print-render-metrics.js",
    "print:prom": "node ./scripts/print-prom.js",
    "print:config": "node ./scripts/print-config.js",
    "print:endpoints": "node ./scripts/print-endpoints.js",
    "poke:scheduler": "node ./scripts/poke-scheduler.js",
    "print:social": "node ./scripts/print-social.js",
    "test:webhook": "node ./scripts/test-webhook.js",
    "load:breaking": "node ./scripts/load-breaking.js",
    "profile:latency": "node ./scripts/profile-latency.js",
    "probe:sources": "node ./scripts/probe-sources.js",
    "synth:webhook:prn": "node ../tools/synth-publisher/cli.js --mode webhook --provider prnewswire --rps 0.5 --duration-sec 300",
    "synth:rss:file": "node ../tools/synth-publisher/cli.js --mode rss-file --file ../tools/synth-publisher/sample.xml --rps 0.5 --duration-sec 300",
    "kill:4000": "powershell -NoProfile -Command \"Get-Process -Id (Get-NetTCPConnection -LocalPort 4000 -ErrorAction SilentlyContinue).OwningProcess | Stop-Process -Force\""
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "firebase-admin": "^12.0.0",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "undici": "^7.14.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.10.0",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^6.0.3",
    "@types/xml2js": "^0.4.14",
    "cross-env": "^7.0.3",
    "dotenv": "^17.2.1",
    "husky": "^9.1.7",
    "jest": "^30.0.5",
    "nodemon": "^3.0.2",
    "rimraf": "^6.0.1",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.2"
  },
  "keywords": [
    "pulse",
    "backend",
    "express"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": "22.x"
  },
  "overrides": {}
}
