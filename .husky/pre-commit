#!/usr/bin/env bash
set -euo pipefail

# Only scan meaningful files (ignore lockfiles, markdown, docs, husky, env examples)
DIFF_FILES=$(git diff --cached --name-only | grep -vE '(^|/)(package-lock\.json|.*\.lock|\.husky/|docs/|README\.md|CHANGELOG\.md|LICENSE|.*\.md|\.env\.example$)')

# Nothing to scan? pass
[ -z "${DIFF_FILES}" ] && exit 0

# Stricter patterns: avoid "sk-" inside words like "microtask", require length
SECRET_REGEX='(\bsk-[A-Za-z0-9_-]{10,}|pk_[A-Za-z0-9_-]{10,}|AIza[0-9A-Za-z\-_]{10,}|ya29\.[0-9A-Za-z\-_\.]{10,}|eyJ[a-zA-Z0-9._-]{10,}|-----BEGIN|-----END)'

# Scan only the selected files; print exact hits if found
if git diff --cached -- ${DIFF_FILES} | grep -nE "${SECRET_REGEX}" > /tmp/secret_hits.txt; then
  echo "❌ Potential secret detected. Hits:"
  sed 's/^/  /' /tmp/secret_hits.txt
  exit 1
fi

echo "✅ Security checks passed."
exit 0
